# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anonima-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Desvios HSE"

# Email (opcional - para notificações)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua-senha-de-app

# MySQL — AWS RDS (para integração com Google Apps Script via /api/hse-report)
DB_HOST=seu-host.rds.amazonaws.com
DB_PORT=3306
DB_USER=desvios
DB_PASSWORD=sua-senha
DB_NAME=desvios

# Token de autenticação da rota /api/hse-report usada pelo Google Apps Script
HSE_REPORT_TOKEN=hse-mse-2026
