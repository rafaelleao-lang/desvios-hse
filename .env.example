# ============================================================
# Banco de dados — MySQL
# ------------------------------------------------------------
# Local (XAMPP):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=desvios
DB_CONNECTION_LIMIT=10

# Produção (Amazon RDS) — basta trocar os valores acima e habilitar SSL:
# DB_HOST=minha-instancia.xxxxxxxx.us-east-1.rds.amazonaws.com
# DB_PORT=3306
# DB_USER=admin
# DB_PASSWORD=senha-forte
# DB_NAME=desvios
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=./certs/rds-combined-ca-bundle.pem

# ============================================================
# Storage de fotos (filesystem local)
# ------------------------------------------------------------
# Opcional — padrões: <projeto>/public/uploads e /uploads
# UPLOAD_DIR=./public/uploads
# UPLOAD_PUBLIC_URL=/uploads

# ============================================================
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Desvios HSE"

# ============================================================
# Acesso / Embed (iframe)
# ------------------------------------------------------------
# O sistema não possui login próprio: a URL é embedada em outro site,
# que controla os níveis de acesso.
# Origens autorizadas a carregar a app em <iframe> (CSP frame-ancestors).
# Separe múltiplas por espaço. 'self' = somente a própria origem.
EMBED_ANCESTORS="'self' https://site-que-embeda.com.br"

# ============================================================
# Email (opcional - para notificações)
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua-senha-de-app

# MySQL — AWS RDS (para integração com Google Apps Script via /api/hse-report)
DB_HOST=seu-host.rds.amazonaws.com
DB_PORT=3306
DB_USER=desvios
DB_PASSWORD=sua-senha
DB_NAME=desvios

# Token de autenticação da rota /api/hse-report usada pelo Google Apps Script
HSE_REPORT_TOKEN=hse-mse-2026
